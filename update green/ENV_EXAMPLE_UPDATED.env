# ========================================
# GREENLIFE CRM - VARIABLES DE ENTORNO
# ========================================
# IMPORTANTE: 
# - Copia este archivo a .env y completa con tus valores
# - NUNCA commitees el .env real a Git
# - Los valores aquí son placeholders/ejemplos solamente

# ========================================
# FRONTEND - REACT
# ========================================
REACT_APP_API_URL=http://localhost:5000
REACT_APP_ENVIRONMENT=development
# Opciones: development, staging, production
REACT_APP_API_TIMEOUT=30000

# ========================================
# BACKEND - BASE DE DATOS
# ========================================
# PostgreSQL (si usas)
DATABASE_URL=postgresql://user:password@localhost:5432/greenlife_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=greenlife_db
DB_USER=postgres
DB_PASSWORD=your_password

# MongoDB (si usas)
MONGODB_URI=mongodb://localhost:27017/greenlife
MONGODB_USER=admin
MONGODB_PASSWORD=your_mongo_password

# ========================================
# BACKEND - COMUNICACIÓN POR EMAIL
# ========================================
# Gmail SMTP
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@greenlife.com

# SendGrid (alternativa)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@greenlife.com

# ========================================
# SEGURIDAD - TOKENS Y SECRETOS
# ========================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=3600
SECRET_KEY=your_django_secret_key_change_this_in_production

# ========================================
# TERCEROS - API KEYS (SI APLICA)
# ========================================
# Stripe (si tienes pagos)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret

# Google OAuth (si usas autenticación)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AWS S3 (si subes archivos)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=greenlife-bucket
AWS_S3_REGION_NAME=us-east-1

# ========================================
# LOGGING Y DEBUG
# ========================================
DEBUG=False
LOG_LEVEL=INFO
# Opciones: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ========================================
# NETLIFY (SI USAS NETLIFY FUNCTIONS)
# ========================================
NETLIFY_AUTH_TOKEN=your_netlify_auth_token
NETLIFY_SITE_ID=your_netlify_site_id
NETLIFY_FUNCTION_TIMEOUT=30

# ========================================
# DEPLOYMENT / PRODUCCIÓN
# ========================================
# Allowed Origins CORS
ALLOWED_ORIGINS=http://localhost:3000,https://greenlife-crm.netlify.app
ENVIRONMENT=production
# Opciones: development, staging, production

# ========================================
# CONFIGURACIÓN OPCIONAL
# ========================================
# Timezone
TIMEZONE=America/Mexico_City

# Límites de tasa (Rate Limiting)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900

# Cache
CACHE_ENABLED=True
CACHE_TTL=3600

# ========================================
# NOTAS DE SEGURIDAD
# ========================================
# 🔒 IMPORTANTE:
# 1. NUNCA incluyas secretos reales en este archivo antes de commitear
# 2. En producción, configura estas variables directamente en:
#    - Netlify: Site settings → Build & Deploy → Environment
#    - Railway: Variables de entorno en el proyecto
#    - Heroku: Config Vars
#    - AWS: Systems Manager Parameter Store o Secrets Manager
# 3. Cambia TODOS los valores por defecto antes de ir a producción
# 4. Usa contraseñas fuertes y únicas
# 5. Rota tus secretos regularmente
